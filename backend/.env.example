# ─── Server Configuration ─────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://remoteshield:CHANGE_ME@localhost:5432/remoteshield_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=remoteshield_db
DB_USER=remoteshield
DB_PASS=CHANGE_ME

# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_TOKEN_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── VPN / Network Security ───────────────────────────────────
# If set to false, you can use the browser from any IP without connecting to WireGuard locally
VPN_REQUIRED=false
# The WireGuard tunnel subnet — all client traffic must come from here
VPN_SUBNET=10.8.0.0/24
# Your VPS static public IP
SERVER_PUBLIC_IP=YOUR_SERVER_STATIC_IP
# The VPN peer IP of the server (wg0 interface)
SERVER_VPN_IP=10.8.0.1

# ─── Admin ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=CHANGE_ME_RUN_node_-e_"console.log(require('bcryptjs').hashSync('your_password',12))"

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Session ──────────────────────────────────────────────────
SESSION_TIMEOUT_HOURS=8
DEVICE_BINDING_ENABLED=true
MAX_SESSIONS_PER_USER=1

# ─── Feature Flags ────────────────────────────────────────────
CLIPBOARD_DISABLED=true
ANOMALY_DETECTION_ENABLED=true
GEO_RESTRICTION_ENABLED=false
ALLOWED_COUNTRIES=IN,US,GB
